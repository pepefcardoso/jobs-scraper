generator client {
  provider     = "prisma-client"
  output       = "../src/generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ExtractionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ApplicationStatus {
  APPLIED
  SCREENED
  INTERVIEWING
  OFFERED
  REJECTED
  GHOSTED
  WITHDRAWN
}

model Job {
  id            String   @id @default(cuid())
  linkedinJobId String   @unique
  searchUrl     String
  searchName    String?
  searchTags    String[]
  scrapedAt     DateTime
  rawHtml       String
  rawText       String
  listMeta      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  extractions Extraction[]
  application Application?
}

model Extraction {
  id             String            @id @default(cuid())
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id])
  provider       String
  model          String
  promptVersion  String
  schemaVersion  String
  status         ExtractionStatus  @default(PENDING)
  attempts       Int               @default(0)
  lastError      String?
  structuredData Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([jobId, provider, promptVersion])
  @@index([status])
}

model Application {
  id            String            @id @default(cuid())
  jobId         String            @unique
  job           Job               @relation(fields: [jobId], references: [id])
  status        ApplicationStatus @default(APPLIED)
  resumeVersion String
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  notes         String?

  @@index([status])
  @@index([appliedAt])
}